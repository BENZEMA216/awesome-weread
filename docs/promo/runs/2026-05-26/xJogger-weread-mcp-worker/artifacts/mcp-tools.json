  "server": "weread",
  "tools": [
    {
      "name": "weread_shelf_sync",
      "gateway_api": "/shelf/sync",
      "description": "获取用户书架列表"
    },
    {
      "name": "weread_user_notebooks",
      "gateway_api": "/user/notebooks",
      "description": "获取用户笔记本概览"
    },
