    },
    {
      "name": "weread_review_list_mine",
      "gateway_api": "/review/list/mine",
      "description": "获取个人想法/笔记列表"
    }
  ],
  "notes": "离线 smoke test：未启动真实 MCP server；此文件用于展示工具清单与网关 API 映射。"
